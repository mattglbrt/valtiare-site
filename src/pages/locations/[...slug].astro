---
import { getCollection, getEntry, render } from 'astro:content';
import LocationLayout from '../../layouts/LocationLayout.astro';
import { getPostsForLocation } from '../../utils/collections';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((location) => ({
    params: { slug: location.id },
    props: { location },
  }));
}

const { location } = Astro.props;
const { data } = location;
const { Content } = await render(location);

const parent = data.world ? await getEntry(data.world) : null;

const allLocations = await getCollection('locations');
const subLocations = allLocations.filter(
  (l) => l.data.world?.id === location.id && l.id !== location.id,
);

const allCharacters = await getCollection('characters');
const associatedCharacters = allCharacters.filter(
  (c) => c.data.world?.id === location.id,
);

const featuredPosts = await getPostsForLocation(location.id);
---

<LocationLayout
  location={location}
  parent={parent}
  subLocations={subLocations}
  associatedCharacters={associatedCharacters}
  featuredPosts={featuredPosts}
>
  <Content />
</LocationLayout>
