---
import { Image } from 'astro:assets';
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostsForLocation } from '../../utils/collections';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((location) => ({
    params: { slug: location.id },
    props: { location },
  }));
}

const { location } = Astro.props;
const { data } = location;
const { Content } = await render(location);

const parent = data.planet ? await getEntry(data.planet) : null;

const allLocations = await getCollection('locations');
const subLocations = allLocations.filter(
  (l) => l.data.planet?.id === location.id && l.id !== location.id,
);

const allCharacters = await getCollection('characters');
const associatedCharacters = allCharacters.filter(
  (c) => c.data.planet?.id === location.id,
);

const featuredPosts = await getPostsForLocation(location.id);
---

<BaseLayout
  title={`${data.name} — Valtiare`}
  description={data.description}
>
  <article>
    {data.coverImage && (
      <div class="relative w-full overflow-hidden border-b border-brass-700/40 bg-ink-900">
        <Image
          src={data.coverImage}
          alt={data.coverImageAlt ?? data.name}
          loading="eager"
          class="block h-auto max-h-[70vh] w-full object-cover"
        />
      </div>
    )}

    <header class="mx-auto max-w-4xl px-6 pt-14 text-center">
      <p class="mb-4 font-sans text-[0.65rem] uppercase tracking-[0.28em] text-stone-500">
        {data.locationType}
      </p>
      <h1 class="heading-rule mx-auto font-display text-4xl md:text-6xl text-parchment-50">
        {data.name}
      </h1>
      <p class="mx-auto mt-8 max-w-2xl font-serif text-lg italic text-parchment-100/90">
        {data.description}
      </p>
      {parent && (
        <p class="mt-6 font-sans text-[0.65rem] uppercase tracking-[0.22em] text-stone-500">
          A part of
          {' '}
          <a
            href={`/locations/${parent.id}/`}
            class="text-brass-500 hover:text-parchment-50"
          >
            {parent.data.name}
          </a>
        </p>
      )}
    </header>

    <div class="mx-auto mt-16 max-w-[680px] px-6">
      <div class="prose-whimsy">
        <Content />
      </div>
      <OrnamentalDivider class="mx-auto mt-16 w-40 text-brass-600" />
    </div>

    {subLocations.length > 0 && (
      <section class="mx-auto mt-12 max-w-6xl px-6">
        <h2 class="heading-rule-left font-display text-2xl text-parchment-50">
          Within {data.name}
        </h2>
        <div class="mt-8 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {subLocations.map((s) => (
            <a
              href={`/locations/${s.id}/`}
              class="group block no-underline"
            >
              <div class="relative overflow-hidden border border-brass-700/60 bg-ink-900">
                {s.data.coverImage ? (
                  <Image
                    src={s.data.coverImage}
                    alt={s.data.coverImageAlt ?? s.data.name}
                    width={800}
                    height={480}
                    class="aspect-[5/3] w-full object-cover transition duration-500 group-hover:scale-[1.02]"
                  />
                ) : (
                  <div class="flex aspect-[5/3] w-full items-center justify-center bg-ink-850">
                    <OrnamentalDivider class="w-24 text-brass-700" />
                  </div>
                )}
              </div>
              <p class="mt-3 font-display text-xl text-parchment-50 group-hover:text-brass-500">
                {s.data.name}
              </p>
              <p class="mt-1 font-sans text-[0.62rem] uppercase tracking-[0.22em] text-stone-500">
                {s.data.locationType}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}

    {associatedCharacters.length > 0 && (
      <section class="mx-auto mt-16 max-w-6xl px-6">
        <h2 class="heading-rule-left font-display text-2xl text-parchment-50">
          Those found here
        </h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {associatedCharacters.map((c) => (
            <a
              href={`/characters/${c.id}/`}
              class="group flex items-center gap-4 border border-ink-700/80 bg-ink-900/50 p-4 no-underline transition hover:border-brass-700"
            >
              {c.data.portrait ? (
                <Image
                  src={c.data.portrait}
                  alt={c.data.portraitAlt ?? c.data.name}
                  width={120}
                  height={160}
                  class="h-20 w-16 flex-none border border-brass-700/70 object-cover"
                />
              ) : (
                <div class="flex h-20 w-16 flex-none items-center justify-center border border-ink-700 bg-ink-850 font-display text-brass-600">?</div>
              )}
              <div>
                <p class="font-display text-lg text-parchment-50 group-hover:text-brass-500">
                  {c.data.name}
                </p>
                {c.data.epithet && (
                  <p class="mt-0.5 font-serif text-sm italic text-stone-400">
                    {c.data.epithet}
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {featuredPosts.length > 0 && (
      <section class="mx-auto mt-16 max-w-6xl px-6 pb-24">
        <h2 class="heading-rule-left font-display text-2xl text-parchment-50">
          Stories set in {data.name}
        </h2>
        <div class="mt-8 grid gap-10 md:grid-cols-2 lg:grid-cols-3">
          {featuredPosts.map((p) => <PostCard post={p} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
