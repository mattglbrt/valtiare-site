---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import Embers from '../../components/Embers.astro';

const locations = await getCollection('locations');
// Planets first, then everything else grouped under their parent planet.
locations.sort((a, b) => {
  if (a.data.locationType === 'planet' && b.data.locationType !== 'planet') return -1;
  if (b.data.locationType === 'planet' && a.data.locationType !== 'planet') return 1;
  return a.data.name.localeCompare(b.data.name);
});
---

<BaseLayout
  title="Locations | Valtiare"
  description="Planets, realms, ruins, and the pilgrim-paths between them."
>
  <section class="relative mx-auto max-w-6xl px-6 pt-24 pb-16 text-center">
    <Embers />
    <div class="relative">
      <p class="mb-4 font-sans text-[0.65rem] uppercase tracking-[0.32em] text-stone-500">
        The Cartography
      </p>
      <h1 class="heading-rule mx-auto font-display text-5xl md:text-6xl text-parchment-50">
        Locations
      </h1>
      <p class="mx-auto mt-8 max-w-xl font-serif text-lg italic text-parchment-100/90">
        Planets, realms, ruins, and the pilgrim-paths between them.
      </p>
      <OrnamentalDivider class="mx-auto mt-10 w-40 text-brass-600" />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      {locations.map((l) => {
        const isPlanet = l.data.locationType === 'planet';
        return (
          <a
            href={`/locations/${l.id}/`}
            class={`group block no-underline ${isPlanet ? 'lg:col-span-2' : ''}`}
          >
            <div class="relative overflow-hidden border border-brass-700/60 bg-ink-900">
              {l.data.coverImage ? (
                <Image
                  src={l.data.coverImage}
                  alt={l.data.coverImageAlt ?? l.data.name}
                  width={isPlanet ? 1600 : 900}
                  height={isPlanet ? 900 : 560}
                  class={`${isPlanet ? 'aspect-[16/9]' : 'aspect-[5/3]'} w-full object-cover transition duration-500 group-hover:scale-[1.02]`}
                />
              ) : (
                <div class="flex aspect-[5/3] w-full items-center justify-center bg-ink-850 p-6 text-center font-display text-xl italic text-brass-600">
                  {l.data.name}
                </div>
              )}
            </div>
            <div class="mt-4">
              <p class={`font-display ${isPlanet ? 'text-3xl' : 'text-2xl'} text-parchment-50 group-hover:text-brass-500`}>
                {l.data.name}
              </p>
              <p class="mt-1 font-sans text-[0.62rem] uppercase tracking-[0.22em] text-stone-500">
                {l.data.locationType}
              </p>
              <p class="mt-3 font-serif text-sm italic text-stone-400 line-clamp-3">
                {l.data.description}
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
