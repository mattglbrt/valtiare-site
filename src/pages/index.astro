---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrnamentalDivider from '../components/OrnamentalDivider.astro';
import ImageFrame from '../components/ImageFrame.astro';

const placeholderHero =
  "data:image/svg+xml;utf8," +
  encodeURIComponent(
    `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 960 540'>
      <rect width='100%' height='100%' fill='#1b1915'/>
      <text x='50%' y='50%' dominant-baseline='middle' text-anchor='middle'
            fill='#8a7635' font-family='Georgia' font-size='28' font-style='italic'>
        placeholder hero — art lives here
      </text>
    </svg>`
  );
---

<BaseLayout>
  <section class="relative mx-auto flex min-h-[70vh] max-w-5xl flex-col items-center justify-center px-6 py-24 text-center">
    <p class="mb-6 font-sans text-xs uppercase tracking-[0.32em] text-stone-500">
      A whimsydark universe
    </p>

    <h1 class="heading-rule font-display text-5xl md:text-7xl text-parchment-50">
      Valtiare
    </h1>

    <p class="mt-10 max-w-xl font-serif text-lg italic text-parchment-100/90">
      A candlelit cabinet of curiosities. An illuminated bestiary from a
      collapsed library. Dark stories told with warm hands.
    </p>

    <OrnamentalDivider class="mt-12 w-48 text-brass-600" />
  </section>

  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="heading-rule-left font-display text-3xl md:text-4xl text-parchment-50">
      The foundation holds.
    </h2>
    <p class="mt-8 text-parchment-100/90">
      This is a Phase&nbsp;1 scaffold. The palette breathes, the serifs settle,
      the grain drifts across the ink. From here we&rsquo;ll grow stories,
      characters, and the cosmology itself.
    </p>

    <ImageFrame
      src={placeholderHero}
      alt="Placeholder hero artwork"
      caption="Placeholder — art will live in this frame"
    />
  </section>
</BaseLayout>
