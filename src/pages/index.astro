---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import OrnamentalDivider from '../components/OrnamentalDivider.astro';
import MediumPill from '../components/MediumPill.astro';
import Embers from '../components/Embers.astro';
import { getPublishedPosts } from '../utils/collections';

const posts = await getPublishedPosts();
const illustrated = posts.filter((p) => p.data.type === 'illustrated-story');
const lore = posts.filter((p) => p.data.type === 'lore');
const featured = illustrated[0] ?? posts[0];
const rest = illustrated.filter((p) => p.id !== featured?.id);
---

<BaseLayout>
  <section class="relative mx-auto flex min-h-[70vh] max-w-5xl flex-col items-center justify-center px-6 py-24 text-center">
    <Embers />

    <h1 class="relative heading-rule font-display text-5xl md:text-7xl text-parchment-50">
      Valtiare
    </h1>

    <p class="relative mt-10 max-w-xl font-serif text-lg italic text-parchment-100/90">
      A candlelit cabinet of curiosities. An illuminated bestiary from a
      collapsed library. Dark stories told with warm hands.
    </p>

    <OrnamentalDivider class="relative mt-12 w-48 text-brass-600" />
  </section>

  {featured && (
    <section class="mx-auto max-w-6xl px-6 pb-24">
      <p class="mb-6 text-center font-sans text-[0.65rem] uppercase tracking-[0.32em] text-stone-500">
        Latest stories
      </p>

      <a
        href={`/stories/${featured.id}/`}
        class="group block no-underline"
      >
        <div class="relative overflow-hidden border border-brass-700/60 bg-ink-900 shadow-[0_40px_80px_-30px_rgba(0,0,0,0.95)]">
          {featured.data.heroImage ? (
            <Image
              src={featured.data.heroImage}
              alt={featured.data.heroImageAlt ?? featured.data.title}
              loading="eager"
              widths={[720, 1080, 1440, 1800]}
              sizes="(min-width: 1280px) 1152px, 92vw"
              class="block h-auto w-full object-cover transition duration-700 group-hover:scale-[1.015]"
            />
          ) : (
            <div class="flex aspect-[16/7] w-full flex-col items-center justify-center gap-6 bg-ink-850 px-8 text-center">
              <OrnamentalDivider class="w-48 text-brass-700" />
              <p class="font-sans text-[0.65rem] uppercase tracking-[0.32em] text-stone-500">
                {featured.data.storyType ? featured.data.storyType.replace(/-/g, ' ') : 'A story'}
              </p>
              <p class="heading-rule font-display text-3xl md:text-4xl italic text-parchment-50">
                {featured.data.title}
              </p>
              <OrnamentalDivider class="w-48 text-brass-700" />
            </div>
          )}
        </div>

        <div class="mx-auto mt-10 max-w-2xl text-center">
          <h2 class="heading-rule mx-auto font-display text-3xl md:text-4xl text-parchment-50 group-hover:text-brass-500">
            {featured.data.title}
          </h2>
          <p class="mt-6 font-serif text-lg italic text-parchment-100/90">
            {featured.data.description}
          </p>
        </div>
      </a>
    </section>
  )}

  {rest.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 pb-24">
      <h2 class="heading-rule-left font-display text-2xl text-parchment-50">
        More from the archives
      </h2>

      <div class="mt-10 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {rest.map((p) => (
          <a
            href={`/stories/${p.id}/`}
            class="group flex flex-col no-underline"
          >
            <div class="relative overflow-hidden border border-brass-700/60 bg-ink-900">
              {p.data.heroImage ? (
                <Image
                  src={p.data.heroImage}
                  alt={p.data.heroImageAlt ?? p.data.title}
                  widths={[480, 720, 960]}
                  sizes="(min-width: 1024px) 32vw, (min-width: 768px) 46vw, 92vw"
                  class="aspect-[5/3] w-full object-cover transition duration-500 group-hover:scale-[1.02]"
                />
              ) : (
                <div class="flex aspect-[5/3] w-full flex-col items-center justify-center gap-3 bg-ink-850 p-6 text-center">
                  <OrnamentalDivider class="w-20 text-brass-700" />
                  <p class="font-display text-xl italic text-brass-600">
                    {p.data.title}
                  </p>
                  <OrnamentalDivider class="w-20 text-brass-700" />
                </div>
              )}
            </div>

            <div class="mt-4 flex-1">
              <p class="font-display text-xl text-parchment-50 group-hover:text-brass-500">
                {p.data.title}
              </p>
              <p class="mt-2 font-serif text-sm italic text-stone-400 line-clamp-3">
                {p.data.description}
              </p>
              {p.data.medium.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {p.data.medium.slice(0, 3).map((m) => <MediumPill medium={m} />)}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {lore.length > 0 && (
    <section class="mx-auto max-w-4xl px-6 pb-24 text-center">
      <p class="mb-4 font-sans text-[0.65rem] uppercase tracking-[0.32em] text-stone-500">
        From the libraries
      </p>
      <OrnamentalDivider class="mx-auto mb-10 w-40 text-brass-600" />

      <div class="grid gap-6 md:grid-cols-2">
        {lore.map((p) => (
          <a
            href={`/stories/${p.id}/`}
            class="group flex flex-col items-center border border-ink-700/80 bg-ink-900/50 p-8 no-underline transition hover:border-brass-700 hover:bg-ink-850/70"
          >
            <OrnamentalDivider class="w-24 text-brass-700" />
            <p class="mt-5 font-display text-2xl italic text-parchment-50 group-hover:text-brass-500">
              {p.data.title}
            </p>
            <p class="mt-3 font-serif text-sm italic text-stone-400 line-clamp-3">
              {p.data.description}
            </p>
            <OrnamentalDivider class="mt-5 w-24 text-brass-700" />
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
