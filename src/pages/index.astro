---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import OrnamentalDivider from '../components/OrnamentalDivider.astro';
import { getPublishedPosts } from '../utils/collections';

const posts = await getPublishedPosts();
const characters = await getCollection('characters');
const locations = await getCollection('locations');
const arcs = await getCollection('arcs');
---

<BaseLayout>
  <section class="relative mx-auto flex min-h-[70vh] max-w-5xl flex-col items-center justify-center px-6 py-24 text-center">
    <p class="mb-6 font-sans text-xs uppercase tracking-[0.32em] text-stone-500">
      A whimsydark universe
    </p>

    <h1 class="heading-rule font-display text-5xl md:text-7xl text-parchment-50">
      Valtiare
    </h1>

    <p class="mt-10 max-w-xl font-serif text-lg italic text-parchment-100/90">
      A candlelit cabinet of curiosities. An illuminated bestiary from a
      collapsed library. Dark stories told with warm hands.
    </p>

    <OrnamentalDivider class="mt-12 w-48 text-brass-600" />
  </section>

  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="heading-rule-left font-display text-3xl md:text-4xl text-parchment-50">
      Content collections are live.
    </h2>
    <p class="mt-8 text-parchment-100/90">
      Phase&nbsp;2 scaffold: schemas are typed, references resolve, and the
      first placeholder stories are walking the Orchard. Routes and layouts
      are still to come — this index is temporarily dumping the raw
      collection state so the data can be eyeballed end-to-end.
    </p>

    <div class="mt-12 grid gap-8 font-sans text-sm text-parchment-100/90">
      <div>
        <h3 class="mb-3 font-display text-xl tracking-wider uppercase text-parchment-50">
          Posts — {posts.length}
        </h3>
        <ul class="space-y-2">
          {posts.map((p) => (
            <li>
              <span class="text-brass-500">{p.data.type}</span>
              <span class="mx-2 text-stone-500">·</span>
              <span class="text-parchment-50">{p.data.title}</span>
              {p.data.arc && (
                <span class="ml-2 text-stone-500">
                  [{p.data.arc.id} #{p.data.arcOrder}]
                </span>
              )}
              {p.data.inUniverseDate && (
                <div class="mt-1 ml-[3.4rem] italic text-stone-500">
                  {p.data.inUniverseDate}
                </div>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-3 font-display text-xl tracking-wider uppercase text-parchment-50">
          Characters — {characters.length}
        </h3>
        <ul class="space-y-2">
          {characters.map((c) => (
            <li>
              <span class="text-parchment-50">{c.data.name}</span>
              {c.data.epithet && (
                <span class="ml-2 italic text-stone-400">{c.data.epithet}</span>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-3 font-display text-xl tracking-wider uppercase text-parchment-50">
          Locations — {locations.length}
        </h3>
        <ul class="space-y-2">
          {locations.map((l) => (
            <li>
              <span class="text-parchment-50">{l.data.name}</span>
              <span class="mx-2 text-stone-500">·</span>
              <span class="text-brass-500">{l.data.locationType}</span>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-3 font-display text-xl tracking-wider uppercase text-parchment-50">
          Arcs — {arcs.length}
        </h3>
        <ul class="space-y-2">
          {arcs.map((a) => (
            <li>
              <span class="text-parchment-50">{a.data.name}</span>
              <span class="mx-2 text-stone-500">·</span>
              <span class="text-brass-500">{a.data.status}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
