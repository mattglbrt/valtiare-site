---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostsInArc } from '../../utils/collections';

export async function getStaticPaths() {
  const arcs = await getCollection('arcs');
  return arcs.map((arc) => ({
    params: { slug: arc.id },
    props: { arc },
  }));
}

const { arc } = Astro.props;
const { data } = arc;
const { Content } = await render(arc);

const posts = await getPostsInArc(arc.id);

const statusLabel = {
  ongoing: 'Ongoing',
  complete: 'Complete',
  hiatus: 'On hiatus',
  unpublished: 'Unpublished',
}[data.status];
---

<BaseLayout
  title={`${data.name} — Valtiare`}
  description={data.description}
  image={data.coverImage?.src}
>
  <article>
    {data.coverImage && (
      <div class="relative w-full overflow-hidden border-b border-brass-700/40 bg-ink-900">
        <Image
          src={data.coverImage}
          alt={data.coverImageAlt ?? data.name}
          loading="eager"
          class="block h-auto max-h-[70vh] w-full object-cover"
        />
      </div>
    )}

    <header class="mx-auto max-w-4xl px-6 pt-14 text-center">
      <p class="mb-4 font-sans text-[0.65rem] uppercase tracking-[0.28em] text-stone-500">
        Arc · {statusLabel}
      </p>
      <h1 class="heading-rule mx-auto font-display text-4xl md:text-6xl text-parchment-50">
        {data.name}
      </h1>
      <p class="mx-auto mt-8 max-w-2xl font-serif text-lg italic text-parchment-100/90">
        {data.description}
      </p>
    </header>

    <div class="mx-auto mt-16 max-w-[680px] px-6">
      <div class="prose-whimsy">
        <Content />
      </div>
      <OrnamentalDivider class="mx-auto mt-16 w-40 text-brass-600" />
    </div>

    {posts.length > 0 && (
      <section class="mx-auto mt-12 max-w-6xl px-6 pb-24">
        <h2 class="heading-rule-left font-display text-2xl text-parchment-50">
          The thread, in order
        </h2>
        <div class="mt-8 grid gap-10 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((p) => <PostCard post={p} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
