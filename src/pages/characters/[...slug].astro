---
import { getCollection, getEntry, render } from 'astro:content';
import CharacterLayout from '../../layouts/CharacterLayout.astro';
import { getPostsForCharacter } from '../../utils/collections';

export async function getStaticPaths() {
  const characters = await getCollection('characters');
  return characters.map((character) => ({
    params: { slug: character.id },
    props: { character },
  }));
}

const { character } = Astro.props;
const { data } = character;
const { Content } = await render(character);

const world = data.world ? await getEntry(data.world) : null;
const featured = await getPostsForCharacter(character.id);
const hasBody = Boolean(character.body?.trim());
---

<CharacterLayout
  character={character}
  world={world}
  featured={featured}
  hasBody={hasBody}
>
  <Content />
</CharacterLayout>
