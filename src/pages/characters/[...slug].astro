---
import { Image } from 'astro:assets';
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import PostCard from '../../components/PostCard.astro';
import Embers from '../../components/Embers.astro';
import { getPostsForCharacter } from '../../utils/collections';

export async function getStaticPaths() {
  const characters = await getCollection('characters');
  return characters.map((character) => ({
    params: { slug: character.id },
    props: { character },
  }));
}

const { character } = Astro.props;
const { data } = character;
const { Content } = await render(character);

const world = data.world ? await getEntry(data.world) : null;
const featured = await getPostsForCharacter(character.id);
---

<BaseLayout
  title={`${data.name} — Valtiare`}
  description={data.description}
  image={data.portrait?.src}
>
  <article>
    <header class="relative mx-auto max-w-5xl px-6 pt-20 pb-4">
      <Embers />
      <div class="relative grid items-start gap-12 md:grid-cols-[minmax(260px,320px)_1fr]">
        <div class="relative overflow-hidden border border-brass-700/70 bg-ink-900 shadow-[0_30px_60px_-20px_rgba(0,0,0,0.9)]">
          {data.portrait ? (
            <Image
              src={data.portrait}
              alt={data.portraitAlt ?? data.name}
              width={640}
              height={860}
              class="block h-auto w-full object-cover"
            />
          ) : (
            <div class="flex aspect-[3/4] w-full items-center justify-center bg-ink-850 p-6 text-center">
              <OrnamentalDivider class="w-28 text-brass-700" />
            </div>
          )}
        </div>

        <div>
          <p class="font-sans text-[0.65rem] uppercase tracking-[0.28em] text-stone-500">
            Character
          </p>
          <h1 class="heading-rule-left mt-4 font-display text-4xl md:text-5xl text-parchment-50">
            {data.name}
          </h1>
          {data.epithet && (
            <p class="mt-6 font-serif text-xl italic text-stone-400">
              {data.epithet}
            </p>
          )}
          <p class="mt-6 font-serif text-lg text-parchment-100/90">
            {data.description}
          </p>

          <div class="mt-6 flex flex-wrap gap-3 font-sans text-[0.62rem] uppercase tracking-[0.18em] text-stone-500">
            <span class="rounded-sm border border-ink-700 bg-ink-850/70 px-2 py-1">
              {data.status}
            </span>
            {world && (
              <a
                href={`/locations/${world.id}/`}
                class="rounded-sm border border-ink-700 bg-ink-850/70 px-2 py-1 no-underline hover:border-brass-700 hover:text-parchment-50"
              >
                {world.data.name}
              </a>
            )}
          </div>
        </div>
      </div>
    </header>

    <div class="mx-auto mt-16 max-w-[680px] px-6">
      <div class="prose-whimsy">
        <Content />
      </div>
      <OrnamentalDivider class="mx-auto mt-16 w-40 text-brass-600" />
    </div>

    {featured.length > 0 && (
      <section class="mx-auto mt-8 max-w-6xl px-6 pb-24">
        <h2 class="heading-rule-left font-display text-2xl text-parchment-50">
          Stories featuring {data.name}
        </h2>
        <div class="mt-8 grid gap-10 md:grid-cols-2 lg:grid-cols-3">
          {featured.map((p) => <PostCard post={p} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
