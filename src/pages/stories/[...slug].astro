---
import { getCollection, render } from 'astro:content';
import IllustratedStoryLayout from '../../layouts/IllustratedStoryLayout.astro';
import LoreLayout from '../../layouts/LoreLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', (p) => p.data.status !== 'draft');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const readingMinutes = (remarkPluginFrontmatter as any)?.readingTime as
  | number
  | undefined;
---

{post.data.type === 'illustrated-story' ? (
  <IllustratedStoryLayout post={post} readingMinutes={readingMinutes}>
    <Content />
  </IllustratedStoryLayout>
) : (
  <LoreLayout post={post} readingMinutes={readingMinutes}>
    <Content />
  </LoreLayout>
)}
