---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import PostCard from '../../components/PostCard.astro';
import FacetFilter from '../../components/FacetFilter.astro';
import { getPublishedPosts } from '../../utils/collections';

const posts = await getPublishedPosts();
const characters = await getCollection('characters');
const locations = await getCollection('locations');
const arcs = await getCollection('arcs');

const characterName = new Map(characters.map((c) => [c.id, c.data.name]));
const locationName = new Map(locations.map((l) => [l.id, l.data.name]));
const arcName = new Map(arcs.map((a) => [a.id, a.data.name]));

// Count occurrences of each facet value across all posts.
function tally<T extends string>(items: T[]): Map<T, number> {
  const m = new Map<T, number>();
  for (const item of items) m.set(item, (m.get(item) ?? 0) + 1);
  return m;
}

const typeCounts = tally(posts.map((p) => p.data.type));
const arcCounts = tally(
  posts.flatMap((p) => (p.data.arc ? [p.data.arc.id] : [])),
);
const charCounts = tally(
  posts.flatMap((p) => p.data.characters.map((c) => c.id)),
);
const locCounts = tally(
  posts.flatMap((p) => [
    ...p.data.locations.map((l) => l.id),
    ...(p.data.world ? [p.data.world.id] : []),
  ]),
);
const mediumCounts = tally(posts.flatMap((p) => p.data.medium));

const typeLabels: Record<string, string> = {
  'illustrated-story': 'Illustrated',
  lore: 'Lore',
};

const facets = [
  {
    key: 'type' as const,
    label: 'Type',
    values: [...typeCounts.entries()].map(([value, count]) => ({
      value,
      label: typeLabels[value] ?? value,
      count,
    })),
  },
  {
    key: 'arc' as const,
    label: 'Arc',
    values: [...arcCounts.entries()].map(([value, count]) => ({
      value,
      label: arcName.get(value) ?? value,
      count,
    })),
  },
  {
    key: 'characters' as const,
    label: 'Characters',
    values: [...charCounts.entries()].map(([value, count]) => ({
      value,
      label: characterName.get(value) ?? value,
      count,
    })),
  },
  {
    key: 'locations' as const,
    label: 'Locations',
    values: [...locCounts.entries()].map(([value, count]) => ({
      value,
      label: locationName.get(value) ?? value,
      count,
    })),
  },
  {
    key: 'medium' as const,
    label: 'Medium',
    values: [...mediumCounts.entries()].map(([value, count]) => ({
      value,
      label: value.replace(/-/g, ' '),
      count,
    })),
  },
];
---

<BaseLayout
  title="Stories — Valtiare"
  description="Illustrated stories and lore entries from the Valtiare universe."
>
  <section class="relative mx-auto max-w-6xl px-6 pt-24 pb-16 text-center">
    <p class="mb-4 font-sans text-[0.65rem] uppercase tracking-[0.32em] text-stone-500">
      The Archives
    </p>
    <h1 class="heading-rule mx-auto font-display text-5xl md:text-6xl text-parchment-50">
      Stories
    </h1>
    <p class="mx-auto mt-8 max-w-xl font-serif text-lg italic text-parchment-100/90">
      Painted vignettes, inherited griefs, and things left unsaid by the last
      warm hearths of Vaelloss.
    </p>
    <OrnamentalDivider class="mx-auto mt-10 w-40 text-brass-600" />
  </section>

  <FacetFilter facets={facets} />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((p) => <PostCard post={p} />)}
    </div>
  </section>
</BaseLayout>
