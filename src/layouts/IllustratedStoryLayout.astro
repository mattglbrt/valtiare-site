---
import { Image } from 'astro:assets';
import { getEntries } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import BaseLayout from './BaseLayout.astro';
import UniverseMeta from '../components/UniverseMeta.astro';
import CharacterCard from '../components/CharacterCard.astro';
import ArcNav from '../components/ArcNav.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import Gallery from '../components/Gallery.astro';
import Lightbox from '../components/Lightbox.astro';
import FontSizeToggle from '../components/FontSizeToggle.astro';
import OrnamentalDivider from '../components/OrnamentalDivider.astro';
import Embers from '../components/Embers.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  readingMinutes?: number;
}

const { post, readingMinutes } = Astro.props;
const { data } = post;

const characters =
  data.characters.length > 0 ? await getEntries(data.characters) : [];

const hasLightboxGallery =
  data.galleryLayout === 'lightbox' && data.gallery.length > 0;
const hasTopGallery =
  (data.galleryLayout === 'grid' ||
    data.galleryLayout === 'masonry' ||
    data.galleryLayout === 'lightbox') &&
  data.gallery.length > 0;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  datePublished: data.date.toISOString(),
  dateModified: (data.updated ?? data.date).toISOString(),
  author: { '@type': 'Person', name: 'Matt Gilbert' },
  publisher: { '@type': 'Organization', name: 'Valtiare' },
  ...(data.heroImage ? { image: data.heroImage.src } : {}),
};
---

<BaseLayout
  title={`${data.title} — Valtiare`}
  description={data.description}
  image={data.heroImage?.src}
  ogType="article"
  structuredData={structuredData}
>
  <article data-font-size="md">
    {data.heroImage ? (
      <>
        <div class="relative w-full overflow-hidden border-b border-brass-700/40 bg-ink-900">
          <Image
            src={data.heroImage}
            alt={data.heroImageAlt ?? data.title}
            loading="eager"
            fetchpriority="high"
            widths={[720, 1080, 1440, 1800, 2400]}
            sizes="100vw"
            class="block h-auto w-full max-h-[85vh] object-cover"
          />
        </div>

        <header class="relative mx-auto max-w-4xl px-6 pt-14 pb-4 text-center">
          <Embers />
          <div class="relative">
            <h1 class="heading-rule mx-auto font-display text-4xl md:text-6xl text-parchment-50">
              {data.title}
            </h1>
            <p class="mx-auto mt-8 max-w-2xl font-serif text-lg italic text-parchment-100/90">
              {data.description}
            </p>
          </div>
        </header>
      </>
    ) : (
      <header class="relative mx-auto max-w-2xl px-6 pt-24 pb-4 text-center">
        <Embers />
        <div class="relative">
          <p class="mb-6 font-sans text-[0.65rem] uppercase tracking-[0.32em] text-stone-500">
            {data.storyType ? `A ${data.storyType.replace(/-/g, ' ')}` : 'A story'}
          </p>
          <OrnamentalDivider class="mx-auto mb-10 w-36 text-brass-600" />
          <h1 class="heading-rule mx-auto font-display text-4xl md:text-5xl text-parchment-50">
            {data.title}
          </h1>
          <p class="mx-auto mt-8 max-w-xl font-serif text-lg italic text-parchment-100/90">
            {data.description}
          </p>
          <OrnamentalDivider class="mx-auto mt-12 w-36 text-brass-600" />
        </div>
      </header>
    )}

    <div class="mt-10">
      <UniverseMeta post={post} readingMinutes={readingMinutes} />
    </div>

    <div class="mx-auto mt-6 flex max-w-4xl items-center justify-end px-6">
      <FontSizeToggle />
    </div>

    <div class="mx-auto max-w-[680px] px-6 py-12">
      {hasTopGallery && (
        <Gallery
          items={data.gallery}
          layout={data.galleryLayout}
          galleryId={post.id}
        />
      )}

      <div class="prose-body">
        <slot />
      </div>

      {data.hasVideo && data.videoUrl && (
        <VideoEmbed url={data.videoUrl} title={data.title} />
      )}

      <OrnamentalDivider class="mx-auto mt-16 w-40 text-brass-600" />
    </div>

    {characters.length > 0 && (
      <section class="mx-auto mt-8 max-w-4xl px-6">
        <h2 class="heading-rule-left font-display text-2xl text-parchment-50">
          Those who walk this story
        </h2>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          {characters.map((c) => <CharacterCard character={c} />)}
        </div>
      </section>
    )}

    <ArcNav post={post} />
    <RelatedPosts post={post} />

    {hasLightboxGallery && <Lightbox />}
  </article>
</BaseLayout>
