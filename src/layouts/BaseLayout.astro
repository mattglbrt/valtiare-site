---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown>;
}

const {
  title = 'Valtiare — handmade art and fiction',
  description = 'Handmade art and short fiction by Matt Gilbert. The home of the Valtiare universe.',
  image,
  ogType = 'website',
  structuredData,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://valtiare.com');
const ogImage = image ? new URL(image, canonical).toString() : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.toString()} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:site_name" content="Valtiare" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0e0d0b" />
    <link rel="alternate" type="application/rss+xml" title="Valtiare" href="/rss.xml" />

    {structuredData && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
      />
    )}
  </head>
  <body class="bg-ink-950 text-parchment-100 font-serif">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:rounded focus:border focus:border-brass-500 focus:bg-ink-900 focus:px-4 focus:py-2 focus:font-sans focus:text-sm focus:text-parchment-50"
    >
      Skip to content
    </a>

    <div class="relative z-10 flex min-h-screen flex-col">
      <Nav />
      <main id="main" class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>

    <div class="atmosphere-layer atmosphere-grain" aria-hidden="true"></div>
    <div class="atmosphere-layer atmosphere-vignette" aria-hidden="true"></div>
  </body>
</html>
