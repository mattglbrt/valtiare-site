---
// Client island — a single lightbox overlay shared by every gallery on the page.
// Galleries mark their thumbnails with data-lightbox-trigger and ship their data
// as a JSON script tag. This island wires it all up on load.
---

<div
  id="valtiare-lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/92 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
>
  <button
    type="button"
    class="absolute left-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-sm border border-brass-700/60 bg-ink-900/70 font-sans text-xs uppercase tracking-wider text-parchment-100 hover:text-brass-500"
    data-lightbox-close
    aria-label="Close viewer"
  >
    Close
  </button>

  <button
    type="button"
    class="absolute left-4 top-1/2 -translate-y-1/2 inline-flex h-14 w-14 items-center justify-center rounded-full border border-brass-700/60 bg-ink-900/70 text-parchment-100 text-2xl hover:text-brass-500"
    data-lightbox-prev
    aria-label="Previous image"
  >
    ‹
  </button>

  <button
    type="button"
    class="absolute right-4 top-1/2 -translate-y-1/2 inline-flex h-14 w-14 items-center justify-center rounded-full border border-brass-700/60 bg-ink-900/70 text-parchment-100 text-2xl hover:text-brass-500"
    data-lightbox-next
    aria-label="Next image"
  >
    ›
  </button>

  <figure class="mx-6 flex max-h-[88vh] max-w-[92vw] flex-col items-center">
    <img
      data-lightbox-image
      alt=""
      class="max-h-[80vh] max-w-full border border-brass-700/70 object-contain"
    />
    <figcaption
      data-lightbox-caption
      class="mt-4 max-w-2xl text-center font-sans text-xs uppercase tracking-[0.18em] text-stone-400"
    ></figcaption>
  </figure>
</div>

<script>
  type LightboxItem = { src: string; alt: string; caption: string };

  const overlay = document.getElementById('valtiare-lightbox');
  if (overlay) {
    const imgEl = overlay.querySelector<HTMLImageElement>('[data-lightbox-image]');
    const captionEl = overlay.querySelector<HTMLElement>('[data-lightbox-caption]');
    const closeBtn = overlay.querySelector<HTMLButtonElement>('[data-lightbox-close]');
    const prevBtn = overlay.querySelector<HTMLButtonElement>('[data-lightbox-prev]');
    const nextBtn = overlay.querySelector<HTMLButtonElement>('[data-lightbox-next]');

    const galleries = new Map<string, LightboxItem[]>();
    document
      .querySelectorAll<HTMLScriptElement>('script[data-lightbox-data]')
      .forEach((node) => {
        const id = node.getAttribute('data-lightbox-data') ?? '';
        try {
          galleries.set(id, JSON.parse(node.textContent ?? '[]'));
        } catch {
          galleries.set(id, []);
        }
      });

    let activeGallery: string | null = null;
    let activeIndex = 0;

    function render() {
      if (!imgEl || !captionEl || !activeGallery) return;
      const items = galleries.get(activeGallery);
      if (!items || items.length === 0) return;
      const item = items[activeIndex];
      imgEl.src = item.src;
      imgEl.alt = item.alt;
      captionEl.textContent = item.caption || item.alt;
    }

    function open(gallery: string, index: number) {
      if (!galleries.has(gallery)) return;
      activeGallery = gallery;
      activeIndex = index;
      overlay!.classList.remove('hidden');
      overlay!.classList.add('flex');
      document.body.style.overflow = 'hidden';
      render();
    }

    function close() {
      overlay!.classList.add('hidden');
      overlay!.classList.remove('flex');
      document.body.style.overflow = '';
      activeGallery = null;
    }

    function step(delta: number) {
      if (!activeGallery) return;
      const items = galleries.get(activeGallery);
      if (!items) return;
      activeIndex = (activeIndex + delta + items.length) % items.length;
      render();
    }

    document
      .querySelectorAll<HTMLElement>('[data-lightbox-trigger]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          const g = btn.getAttribute('data-lightbox-trigger') ?? '';
          const i = Number(btn.getAttribute('data-lightbox-index') ?? 0);
          open(g, i);
        });
      });

    closeBtn?.addEventListener('click', close);
    prevBtn?.addEventListener('click', () => step(-1));
    nextBtn?.addEventListener('click', () => step(1));

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    document.addEventListener('keydown', (e) => {
      if (overlay.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') step(-1);
      if (e.key === 'ArrowRight') step(1);
    });

    // Touch swipe
    let touchStartX = 0;
    overlay.addEventListener(
      'touchstart',
      (e) => {
        touchStartX = e.changedTouches[0].clientX;
      },
      { passive: true },
    );
    overlay.addEventListener(
      'touchend',
      (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 40) step(dx < 0 ? 1 : -1);
      },
      { passive: true },
    );
  }
</script>
