---
interface FacetValue {
  value: string;
  label: string;
  count: number;
}

interface Facet {
  key: 'type' | 'arc' | 'characters' | 'locations' | 'medium';
  label: string;
  values: FacetValue[];
}

interface Props {
  facets: Facet[];
}

const { facets } = Astro.props;
---

<aside
  class="mx-auto max-w-6xl border-y border-ink-700/70 bg-ink-900/40 px-6 py-6"
  data-facet-filter
>
  <div class="flex items-start justify-between gap-4">
    <p class="font-sans text-[0.65rem] uppercase tracking-[0.28em] text-stone-500">
      Narrow the archives
    </p>
    <button
      type="button"
      class="font-sans text-[0.65rem] uppercase tracking-[0.22em] text-brass-500 hover:text-parchment-50"
      data-facet-clear
    >
      Clear
    </button>
  </div>

  <div class="mt-5 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {facets
      .filter((f) => f.values.length > 0)
      .map((facet) => (
        <div>
          <p class="mb-2 font-sans text-[0.62rem] uppercase tracking-[0.22em] text-stone-500">
            {facet.label}
          </p>
          <div class="flex flex-wrap gap-2">
            {facet.values.map((v) => (
              <button
                type="button"
                class="inline-flex items-center gap-1 rounded-sm border border-ink-700 bg-ink-850/70 px-2.5 py-1 font-sans text-[0.68rem] uppercase tracking-[0.14em] text-stone-400 transition hover:border-brass-700 hover:text-parchment-50 aria-pressed:border-brass-500 aria-pressed:bg-ink-800 aria-pressed:text-parchment-50"
                aria-pressed="false"
                data-facet={facet.key}
                data-facet-value={v.value}
              >
                <span>{v.label}</span>
                <span class="text-stone-500">{v.count}</span>
              </button>
            ))}
          </div>
        </div>
      ))}
  </div>

  <p
    class="mt-5 hidden font-sans text-xs italic text-stone-500"
    data-facet-empty
  >
    No stories match the current filters.
  </p>
</aside>

<script>
  type FacetKey = 'type' | 'arc' | 'characters' | 'locations' | 'medium';
  const FACETS: FacetKey[] = ['type', 'arc', 'characters', 'locations', 'medium'];

  const root = document.querySelector<HTMLElement>('[data-facet-filter]');
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-post-card]'),
  );
  const emptyEl = root?.querySelector<HTMLElement>('[data-facet-empty]');

  const active: Record<FacetKey, Set<string>> = {
    type: new Set(),
    arc: new Set(),
    characters: new Set(),
    locations: new Set(),
    medium: new Set(),
  };

  function cardMatches(card: HTMLElement): boolean {
    for (const key of FACETS) {
      const selected = active[key];
      if (selected.size === 0) continue;
      const raw = card.getAttribute(`data-${key === 'type' ? 'type' : key}`) ?? '';
      const values = raw ? raw.split(',') : [];
      // OR within a facet — card matches if any value intersects
      const hit = [...selected].some((v) => values.includes(v));
      if (!hit) return false;
    }
    return true;
  }

  function apply() {
    let visible = 0;
    for (const card of cards) {
      const match = cardMatches(card);
      card.classList.toggle('hidden', !match);
      if (match) visible++;
    }
    emptyEl?.classList.toggle('hidden', visible > 0);
  }

  root
    ?.querySelectorAll<HTMLButtonElement>('[data-facet]')
    .forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-facet') as FacetKey;
        const value = btn.getAttribute('data-facet-value') ?? '';
        const set = active[key];
        if (set.has(value)) {
          set.delete(value);
          btn.setAttribute('aria-pressed', 'false');
        } else {
          set.add(value);
          btn.setAttribute('aria-pressed', 'true');
        }
        apply();
      });
    });

  root
    ?.querySelector<HTMLButtonElement>('[data-facet-clear]')
    ?.addEventListener('click', () => {
      for (const key of FACETS) active[key].clear();
      root
        .querySelectorAll<HTMLButtonElement>('[data-facet]')
        .forEach((btn) => btn.setAttribute('aria-pressed', 'false'));
      apply();
    });
</script>
