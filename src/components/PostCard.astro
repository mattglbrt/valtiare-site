---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import MediumPill from './MediumPill.astro';
import OrnamentalDivider from './OrnamentalDivider.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  size?: 'default' | 'large';
}

const { post, size = 'default' } = Astro.props;
const { data } = post;
const href = `/stories/${post.id}/`;

// Data attributes for the FacetFilter island.
const filterAttrs = {
  'data-post-card': '',
  'data-type': data.type,
  'data-arc': data.arc?.id ?? '',
  'data-characters': data.characters.map((c) => c.id).join(','),
  'data-locations': [
    ...data.locations.map((l) => l.id),
    ...(data.world ? [data.world.id] : []),
  ].join(','),
  'data-medium': data.medium.join(','),
};
---

{data.type === 'illustrated-story' ? (
  <a href={href} class="group block no-underline" {...filterAttrs}>
    <div class={`relative overflow-hidden border border-brass-700/60 bg-ink-900 ${size === 'large' ? '' : ''}`}>
      {data.heroImage ? (
        <Image
          src={data.heroImage}
          alt={data.heroImageAlt ?? data.title}
          width={size === 'large' ? 1400 : 900}
          height={size === 'large' ? 840 : 560}
          class="aspect-[5/3] w-full object-cover transition duration-500 group-hover:scale-[1.02]"
        />
      ) : (
        <div class="flex aspect-[5/3] w-full items-center justify-center bg-ink-850 p-6 text-center font-display text-2xl italic text-brass-600">
          {data.title}
        </div>
      )}
    </div>

    <div class="mt-4">
      <p class={`font-display ${size === 'large' ? 'text-3xl' : 'text-xl'} text-parchment-50 group-hover:text-brass-500`}>
        {data.title}
      </p>
      <p class="mt-2 font-serif text-sm italic text-stone-400 line-clamp-3">
        {data.description}
      </p>
      {data.medium.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {data.medium.slice(0, 3).map((m) => <MediumPill medium={m} />)}
        </div>
      )}
    </div>
  </a>
) : (
  <a
    href={href}
    class="group flex flex-col justify-between border border-ink-700/80 bg-ink-900/50 p-6 no-underline transition hover:border-brass-700 hover:bg-ink-850/70"
    {...filterAttrs}
  >
    <div class="flex items-center justify-center py-2">
      <OrnamentalDivider class="w-32 text-brass-700" />
    </div>

    <div class="mt-2 text-center">
      <p class="font-sans text-[0.62rem] uppercase tracking-[0.28em] text-stone-500">
        Lore
      </p>
      <p class={`mt-4 font-display ${size === 'large' ? 'text-3xl' : 'text-2xl'} italic text-parchment-50 group-hover:text-brass-500`}>
        {data.title}
      </p>
      <p class="mt-4 font-serif text-sm italic text-stone-400 line-clamp-4">
        {data.description}
      </p>
    </div>

    <div class="mt-6 flex items-center justify-center py-2">
      <OrnamentalDivider class="w-32 text-brass-700" />
    </div>
  </a>
)}
