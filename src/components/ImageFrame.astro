---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}
const {
  src,
  alt,
  caption,
  width,
  height,
  class: className = '',
  loading = 'lazy',
} = Astro.props;
---

<figure class={`group my-10 ${className}`}>
  <div
    class="relative overflow-hidden border border-brass-700/70 bg-ink-900 shadow-[0_30px_60px_-20px_rgba(0,0,0,0.9)] ring-1 ring-inset ring-black/40"
  >
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      class="block w-full h-auto"
    />
  </div>
  {caption && (
    <figcaption class="mt-3 text-center font-sans text-xs uppercase tracking-[0.18em] text-stone-500">
      {caption}
    </figcaption>
  )}
</figure>
