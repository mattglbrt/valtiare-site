---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type GalleryItem = {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
};

interface Props {
  items: GalleryItem[];
  layout: 'grid' | 'masonry' | 'sequential' | 'lightbox';
  galleryId?: string;
}

const { items, layout, galleryId = 'gallery' } = Astro.props;

if (items.length === 0 || layout === 'sequential') {
  // Sequential is handled inline by the MDX body — nothing to render here.
}

const wrapperClass =
  layout === 'grid'
    ? 'grid gap-4 sm:grid-cols-2 lg:grid-cols-3'
    : layout === 'masonry'
      ? 'columns-1 gap-4 sm:columns-2 lg:columns-3 [&>*]:mb-4 [&>*]:break-inside-avoid'
      : layout === 'lightbox'
        ? 'grid gap-3 grid-cols-2 sm:grid-cols-3 md:grid-cols-4'
        : '';

const isLightbox = layout === 'lightbox';
---

{items.length > 0 && layout !== 'sequential' && (
  <div
    class={`my-12 ${wrapperClass}`}
    data-gallery={isLightbox ? galleryId : undefined}
  >
    {items.map((item, i) => (
      <figure class="group m-0">
        {isLightbox ? (
          <button
            type="button"
            class="block w-full overflow-hidden border border-brass-700/60 bg-ink-900 p-0"
            data-lightbox-trigger={galleryId}
            data-lightbox-index={i}
            aria-label={`Open image: ${item.alt}`}
          >
            <Image
              src={item.src}
              alt={item.alt}
              class="block h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
            />
          </button>
        ) : (
          <div class="overflow-hidden border border-brass-700/70 bg-ink-900 shadow-[0_20px_40px_-20px_rgba(0,0,0,0.8)]">
            <Image
              src={item.src}
              alt={item.alt}
              class="block h-auto w-full"
            />
          </div>
        )}
        {item.caption && (
          <figcaption class="mt-2 text-center font-sans text-[0.68rem] uppercase tracking-[0.18em] text-stone-500">
            {item.caption}
          </figcaption>
        )}
      </figure>
    ))}
  </div>
)}

{isLightbox && items.length > 0 && (
  <script
    type="application/json"
    data-lightbox-data={galleryId}
    set:html={JSON.stringify(
      items.map((i) => ({ src: i.src.src, alt: i.alt, caption: i.caption ?? '' })),
    )}
  />
)}
