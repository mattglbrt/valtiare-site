---
import OrnamentalDivider from './OrnamentalDivider.astro';
const year = new Date().getFullYear();
---

<footer class="relative z-10 mt-24 border-t border-ink-700/80 bg-ink-900/60">
  <div class="mx-auto max-w-4xl px-6 py-16 text-center">
    <OrnamentalDivider class="mx-auto mb-10 w-40 text-brass-600" />
    <p class="firelit-wordmark font-display text-xl tracking-[0.18em] uppercase text-parchment-50">
      Valtiare
    </p>
    <p class="mt-4 font-sans text-xs uppercase tracking-[0.22em] text-stone-500">
      All artwork handmade by Matt Gilbert
    </p>
    <p class="mt-2 font-sans text-xs tracking-[0.12em] text-stone-500">
      © {year} Matt Gilbert. All rights reserved.
    </p>
  </div>
</footer>
